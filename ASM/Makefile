### COLORS ###
DEF_COLOR = \033[0;39m
GRAY = \033[0;90m
RED = \033[0;91m
GREEN = \033[0;92m
YELLOW = \033[0;93m
BLUE = \033[0;94m
MAGENTA = \033[0;95m
CYAN = \033[0;96m
WHITE = \033[0;97m

### VARIABLES ###

ASM := nasm
CC := gcc

# elf64 is the expected file format for linux x86-64 architectures
ASMFLAGS := -felf64
CFLAGS := -Wall -Wextra -Werror

SRC := Colleen.s Grace.s
OBJ := $(SRC:.s=.o)
NAME := $(basename $(SRC))

### COMPILATION ###

all: $(NAME)

%: %.o
	$(CC) $(CFLAGS) $< -o $@
	@echo "$(GREEN)-> $@ compiled!$(DEF_COLOR)"

%.o: %.s
	$(ASM) $(ASMFLAGS) $< -o $@
	@echo "$(GREEN)-> $@ assembled!$(DEF_COLOR)"

### MEMO ###
# 	Special variables :
#		$@	Represents the target file that is being generated by the rule
#		$<	Represents the first dependency of the rule
#		$^	Represents all the dependencies of the rule, separated by spaces.
#		$?	Represents a list of dependencies that are newer than the target file.
#		$*	Represents the stem of the target filename (without the extension)

### RULES ###

clean:
	@rm -f $(OBJ)
	@rm -f tmp_*
	@rm -f Sully_*
	@rm -f Grace_kid.s
	@echo "$(BLUE)ASM quines object files removed.$(DEF_COLOR)"

fclean: clean
	@rm -f $(NAME)
	@echo "$(RED)ASM quines binaries removed.$(DEF_COLOR)"

re: fclean all
	@echo "$(CYAN)ASM quines cleaned and rebuilt from scratch.$(DEF_COLOR)"

.PHONY: all clean fclean re